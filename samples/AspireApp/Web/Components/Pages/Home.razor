@page "/"
@using ElBruno.AgentsOrchestration.Orchestration
@using ElBruno.AgentsOrchestration.Workspace
@using ElBruno.AgentsOrchestration.Agents
@using ElBruno.AgentsOrchestration.Views
@using AgentsOrchestration.Web.Models
@inject IServiceScopeFactory ScopeFactory
@inject AgentOutputStore OutputStore
@inject IJSRuntime JS

<PageTitle>Orchestration Dashboard</PageTitle>

<div class="dashboard-layout">
    <div class="split-pane">
        @if (_chatCollapsed)
        {
            <aside class="chat-rail" @onclick="ExpandChat">
                <span class="chat-rail-icon" title="Expand chat">💬</span>
                <span class="chat-rail-expand" title="Expand chat">»</span>
                @if (ChatMessages.Count > 0)
                {
                    <span class="chat-rail-badge">@ChatMessages.Count</span>
                }
            </aside>
        }
        else
        {
            <section class="split-left" style="flex: @LeftFlex">
                <div class="chat-panel-header">
                    <span class="chat-panel-title">💬 Chat</span>
                    <button class="btn btn-sm btn-link chat-collapse-btn" @onclick="CollapseChat" title="Collapse chat">
                        «
                    </button>
                </div>
                <PromptInput @bind-Prompt="Prompt" IsRunning="IsRunning" OnRun="RunAsync" OnCancel="CancelAsync"
                             OnClear="ClearConversation" Messages="ChatMessages" />
            </section>
            <div class="split-handle" @onpointerdown="OnHandlePointerDown"></div>
        }
        <section class="split-right"
                 style="flex: @(_chatCollapsed ? 1 : RightFlex); display: flex; flex-direction: column; overflow: hidden;">
            <div class="d-flex border-bottom bg-light tab-bar">
                <button
                    class="btn btn-sm @(ActiveTab == "chart" ? "btn-light fw-bold border-bottom-0" : "btn-link text-decoration-none text-secondary") rounded-0 px-3 py-2"
                    @onclick="@(() => ActiveTab = "chart")">
                    <i class="bi bi-diagram-3"></i> Agent Chart
                </button>
                <button
                    class="btn btn-sm @(ActiveTab == "plan" ? "btn-light fw-bold border-bottom-0" : "btn-link text-decoration-none text-secondary") rounded-0 px-3 py-2"
                    @onclick="@(() => ActiveTab = "plan")">
                    <i class="bi bi-card-checklist"></i> Implementation Plan
                </button>
                <button
                    class="btn btn-sm @(ActiveTab == "flow" ? "btn-light fw-bold border-bottom-0" : "btn-link text-decoration-none text-secondary") rounded-0 px-3 py-2"
                    @onclick="@(() => ActiveTab = "flow")">
                    <i class="bi bi-list-nested"></i> Call Flow
                </button>
            </div>
            
            <div style="flex: 1; overflow: hidden; position: relative;">
                @if (ActiveTab == "chart")
                {
                    <AgentCanvasChart @ref="_canvasChart" Nodes="AgentNodes" Connections="AgentConnections"
                                      OnNodeClicked="HandleNodeClick" />
                }
                else if (ActiveTab == "plan")
                {
                    <div class="h-100 overflow-auto p-2">
                        @if (_currentPlan is not null)
                        {
                            <PlanViewer Plan="_currentPlan" CurrentPhaseIndex="_currentPhaseIndex"
                                        ShowActions="_planAwaitingApproval" IsExecuting="IsRunning && !_planAwaitingApproval"
                                        OnApprove="ApprovePlan" OnCancel="RejectPlan" PlanMarkdown="@_currentPlanMarkdown" />
                        }
                        else
                        {
                            <div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted">
                                <i class="bi bi-card-checklist display-4 mb-3"></i>
                                <p>No execution plan yet. Submit a prompt to generate one.</p>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="h-100 overflow-auto bg-light">
                        <AgentFlow Graph="_callGraph" />
                    </div>
                }
            </div>

            @* Status bar — always visible below tabs *@
            @if (IsRunning && !_planAwaitingApproval && _currentPlan is not null)
            {
                <div class="orchestration-status-bar">
                    <PhaseProgress TotalPhases="_currentPlan.Phases.Count" CurrentPhase="_currentPhaseIndex"
                                   CurrentPhaseName="@_currentPhaseName" />
                </div>
            }
        </section>
    </div>

    <section class="dashboard-bottom-section">
        <div class="app-launch-controls">
            <button class="btn btn-sm @(IsAppRunning ? "btn-outline-danger" : "btn-outline-success")"
                    disabled="@(IsRunning || (!_buildSucceeded && !IsAppRunning))"
                    @onclick="@(IsAppRunning? StopAppAsync : LaunchAppAsync)">
                @(IsAppRunning ? "⏹ Stop App" : "🚀 Launch App")
            </button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="CopyFileLocationAsync" title="Copy file location"
                    disabled="@(!_buildSucceeded || IsRunning)">
                <i class="bi bi-folder-symlink"></i> Copy Location
            </button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="CopyRunCommandAsync" title="Copy run command"
                    disabled="@(!_buildSucceeded || IsRunning)">
                <i class="bi bi-terminal"></i> Copy Command
            </button>
            @if (IsAppRunning)
            {
                <span class="app-status-badge running">● Running</span>
            }
        </div>
        <ActivityFeed Items="Activities" />
    </section>
</div>

@* Agent Output Modal *@
<AgentOutputModal IsVisible="_showAgentOutputModal" AgentRole="_selectedAgentRole" Output="_selectedAgentOutput"
                  TaskDescription="_selectedAgentTask" OnClose="CloseAgentOutputModal" />

@code {
    private bool IsRunning;
    private bool IsAppRunning;
    private bool _buildSucceeded;
    private CancellationTokenSource? _runCts;
    private OrchestrationService? _lastService;
    private WorkspaceManager? _lastWorkspaceManager;
    private AppRunner? _appRunner;
    private string Prompt { get; set; } = string.Empty;
    private string ActiveTab { get; set; } = "chart";
    private AgentCallGraph _callGraph = new();
    private List<ActivityItem> Activities { get; } = [];
    private List<ChatMessage> ChatMessages { get; } = [];
    private string? _lastBuildResult;
    private List<AgentConnection> AgentConnections { get; } = [];
    private List<AgentNodeState> AgentNodes { get; } = [];
    private AgentCanvasChart? _canvasChart;
    
    // Plan approval workflow
    private ExecutionPlan? _currentPlan;
    private string? _currentPlanMarkdown;
    private bool _planAwaitingApproval;
    private TaskCompletionSource<bool>? _planApprovalTcs;
    private int _currentPhaseIndex;
    private string? _currentPhaseName;
    private string? _currentSessionId;
    
    // Agent output modal
    private bool _showAgentOutputModal;
    private AgentRole _selectedAgentRole;
    private string _selectedAgentOutput = "";
    private string? _selectedAgentTask;

    private static readonly Dictionary<string, (string Color, string Icon)> AgentStyles =
        new(StringComparer.OrdinalIgnoreCase)
        {
            { "Orchestrator", ("#8b949e", "\U0001f3af") },
            { "Planner", ("#58a6ff", "\U0001f4cb") },
            { "Coder", ("#3fb950", "\U0001f4bb") },
            { "Designer", ("#f778ba", "\U0001f3a8") },
            { "Researcher", ("#6610f2", "\U0001f50d") },
            { "Fixer", ("#fd7e14", "\U0001f527") },
            { "BuildReviewer", ("#20c997", "\U0001f9d0") },
            { "SecurityExpert", ("#dc3545", "\U0001f512") },
            { "TestingExpert", ("#17a2b8", "\u2705") },
            { "DocumentationExpert", ("#6f42c1", "\U0001f4da") },
            { "SoftwareArchitect", ("#fd7e14", "\U0001f3d7") },
        };

    protected override void OnInitialized()
    {
        InitializeAllAgents();
    }

    private void InitializeAllAgents()
    {
        AgentNodes.Clear();
        AgentConnections.Clear();
        foreach (var (name, (color, icon)) in AgentStyles)
        {
            AgentNodes.Add(new AgentNodeState
            {
                Name = name,
                Color = color,
                Icon = icon,
                Status = "idle",
                Instruction = "Idle"
            });
        }
    }

    private static string GetAgentColor(string name)
    {
        return AgentStyles.TryGetValue(name, out var style) ? style.Color : "#8b949e";
    }
    
    private async Task CopyFileLocationAsync()
    {
        if (_lastWorkspaceManager?.WorkspacePath is { } path)
        {
            var fullPath = Path.GetFullPath(path);
            await JS.InvokeVoidAsync("copyToClipboard", fullPath);
        }
    }

    private async Task CopyRunCommandAsync()
    {
        if (_lastWorkspaceManager?.WorkspacePath is { } path)
        {
            var csprojFiles = Directory.GetFiles(path, "*.csproj", SearchOption.AllDirectories);
            if (csprojFiles.Length > 0)
            {
                var csprojPath = Path.GetFullPath(csprojFiles[0]);
                await JS.InvokeVoidAsync("copyToClipboard", $"dotnet run --project \"{csprojPath}\"");
            }
        }
    }

    private async Task RunAsync()
    {
        if (string.IsNullOrWhiteSpace(Prompt)) return;

        ChatMessages.Add(new ChatMessage("user", Prompt, DateTimeOffset.UtcNow));

        var currentPrompt = Prompt;
        Prompt = string.Empty;
        IsRunning = true;
        _planAwaitingApproval = false;
        _currentPlan = null;
        _currentPlanMarkdown = null;
        _currentPhaseIndex = 0;
        _currentPhaseName = null;
        ResetStatuses();
        _callGraph = new();
        _lastBuildResult = null;
        _buildSucceeded = false;
        _runCts = new CancellationTokenSource();
        _currentSessionId = Guid.NewGuid().ToString("N");

        // Reset canvas connections and phase badges for the new run
        if (_canvasChart is not null)
            await _canvasChart.ResetAllAsync();

        using var scope = ScopeFactory.CreateScope();
        var service = scope.ServiceProvider.GetRequiredService<OrchestrationService>();
        _lastService = service;
        _lastWorkspaceManager = scope.ServiceProvider.GetRequiredService<IWorkspace>() as WorkspaceManager;

        // Set up plan approval callback based on settings
        var autoApprove = await GetAutoApproveSetting();
        
        service.PlanApprovalCallback = async (plan, markdown) =>
        {
            _currentPlan = plan;
            _currentPlanMarkdown = markdown;
            
            if (autoApprove)
            {
                // Auto-approve but still show the plan
                _planAwaitingApproval = false;
                await InvokeAsync(StateHasChanged);
                return true;
            }
            else
            {
                // Wait for user approval
                _planApprovalTcs = new TaskCompletionSource<bool>();
                _planAwaitingApproval = true;
                await InvokeAsync(StateHasChanged);
                return await _planApprovalTcs.Task;
            }
        };

        // Build context from full conversation
        var contextPrompt = ChatMessages.Count > 1
            ? $"Conversation so far:\n{string.Join("\n", ChatMessages.Select(m => $"[{m.Role}]: {m.Content}"))}\n\nLatest request: {currentPrompt}"
            : currentPrompt;

        try
        {
            var readEvents = Task.Run(async () =>
            {
                await foreach (var evt in service.Events.Reader.ReadAllAsync(_runCts.Token))
                {
                    ApplyEvent(evt);
                }
            }, _runCts.Token);

            await service.RunAsync(new OrchestrationRequest(contextPrompt), _runCts.Token);
            service.Events.Writer.TryComplete();
            await readEvents;

            var completionMsg = _lastBuildResult is not null
                ? $"Orchestration completed. {_lastBuildResult}"
                : "Orchestration completed successfully.";
            ChatMessages.Add(new ChatMessage("assistant", completionMsg, DateTimeOffset.UtcNow));
        }
        catch (OperationCanceledException)
        {
            Activities.Add(new ActivityItem(DateTimeOffset.UtcNow, "Cancelled", "Orchestration cancelled"));
            ChatMessages.Add(new ChatMessage("assistant", "Orchestration was cancelled.", DateTimeOffset.UtcNow));
        }
        finally
        {
            IsRunning = false;
            _planAwaitingApproval = false;
            if (_canvasChart is not null)
                await _canvasChart.DeactivateAllAsync();
            _runCts.Dispose();
            _runCts = null;
        }
    }
    
    private async Task ApprovePlan()
    {
        _planAwaitingApproval = false;
        _planApprovalTcs?.SetResult(true);
        await InvokeAsync(StateHasChanged);
    }
    
    private async Task RejectPlan()
    {
        _planAwaitingApproval = false;
        _planApprovalTcs?.SetResult(false);
        _runCts?.Cancel();
        await InvokeAsync(StateHasChanged);
    }
    
    private async Task HandleNodeClick(string nodeName)
    {
        if (string.IsNullOrEmpty(_currentSessionId)) return;
        
        if (Enum.TryParse<AgentRole>(nodeName, ignoreCase: true, out var role))
        {
            var output = OutputStore.GetLatestOutput(_currentSessionId, role);
            if (output is not null)
            {
                _selectedAgentRole = role;
                _selectedAgentOutput = output.Output;
                _selectedAgentTask = output.TaskDescription;
                _showAgentOutputModal = true;
                await InvokeAsync(StateHasChanged);
            }
        }
    }
    
    private async Task CloseAgentOutputModal()
    {
        _showAgentOutputModal = false;
        await InvokeAsync(StateHasChanged);
    }

    private Task CancelAsync()
    {
        _runCts?.Cancel();
        return Task.CompletedTask;
    }

    private void ClearConversation()
    {
        ChatMessages.Clear();
        Activities.Clear();
        _buildSucceeded = false;
        _callGraph = new();
        _currentPlan = null;
        _currentPlanMarkdown = null;
        _currentPhaseIndex = 0;
        _currentPhaseName = null;
        _planAwaitingApproval = false;
        ResetStatuses();
    }

    private async Task LaunchAppAsync()
    {
        if (_lastWorkspaceManager is null) return;
        try
        {
            if (_appRunner is not null)
            {
                await _appRunner.StopAsync();
                _appRunner.Dispose();
                _appRunner = null;
            }
            _appRunner = new AppRunner();
            _appRunner.OnLogReceived += line =>
            {
                var logEvt = new AppLogEvent(DateTimeOffset.UtcNow, line);
                ApplyEvent(logEvt);
            };
            var launched = await _appRunner.LaunchAsync(_lastWorkspaceManager.WorkspacePath, CancellationToken.None);
            IsAppRunning = launched && _appRunner.IsRunning;
            if (IsAppRunning)
            {
                ApplyEvent(new AppLaunchedEvent(DateTimeOffset.UtcNow, _lastWorkspaceManager.WorkspacePath));
            }
        }
        catch (Exception ex)
        {
            Activities.Add(new ActivityItem(DateTimeOffset.UtcNow, "Error", $"Failed to launch app: {ex.Message}"));
        }
    }

    private async Task StopAppAsync()
    {
        if (_appRunner is null) return;
        try
        {
            await _appRunner.StopAsync();
            _appRunner.Dispose();
            _appRunner = null;
            IsAppRunning = false;
            ApplyEvent(new AppStoppedEvent(DateTimeOffset.UtcNow));
        }
        catch (Exception ex)
        {
            Activities.Add(new ActivityItem(DateTimeOffset.UtcNow, "Error", $"Failed to stop app: {ex.Message}"));
        }
    }

    private void ApplyEvent(OrchestrationEvent evt)
    {
        TrackAgentCall(evt);
        var type = evt.GetType().Name;
        var message = evt switch
        {
            OrchestrationStartedEvent started => $"Started: {started.Prompt}",
            PlanGeneratedEvent planGen => "📋 Plan generated - awaiting approval",
            PlanApprovedEvent approved => approved.AutoApproved ? "✅ Plan auto-approved" : "✅ Plan approved - executing",
            PhaseStartedEvent phaseStart => $"Phase {phaseStart.PhaseIndex}: {phaseStart.PhaseName}",
            AgentActivatedEvent activated => $"{activated.Role} active: {activated.TaskDescription}",
            AgentCompletedEvent completed => $"{completed.Role} completed",
            FileCreatedEvent file => $"File updated: {file.FilePath}",
            BuildValidationEvent build => build.Success ? "\u2705 Build succeeded" : $"\u274c Build failed: {build.Output}",
            FixAttemptStartedEvent fixStart => $"\U0001f527 Fix attempt {fixStart.Attempt} started",
            FixAttemptCompletedEvent fixEnd => fixEnd.Success
                ? $"\u2705 Fix attempt {fixEnd.Attempt} succeeded"
                : $"\u274c Fix attempt {fixEnd.Attempt} failed",
            ResearchRequestedEvent research => $"\U0001f50d {research.RequestingAgent} requested research: {research.Query}",
            ResearchCompletedEvent researchDone => $"\u2705 Research completed: {researchDone.SourcesFound} sources in {researchDone.Duration.TotalSeconds:F1}s",
            AgentCommunicationEvent comm => $"\U0001f504 {comm.FromAgent} \u2192 {comm.ToAgent}: {comm.Summary}",
            AppLaunchedEvent launched => $"\U0001f680 App launched: {launched.WorkspacePath}",
            AppStoppedEvent => "\u23f9 App stopped",
            AppLogEvent log => $"[app] {log.LogLine}",
            OrchestrationCompletedEvent done => done.FinalResult.Summary,
            OrchestrationErrorEvent error => $"Error: {error.Error}",
            _ => type
        };

        Activities.Add(new ActivityItem(evt.Timestamp, type, message));

        // Handle plan events
        if (evt is PlanGeneratedEvent planGenerated)
        {
            // Auto-switch to plan tab when plan is generated
            ActiveTab = "plan";
            _ = InvokeAsync(StateHasChanged);
        }
        else if (evt is PlanApprovedEvent)
        {
            // Switch back to chart tab when plan is approved
            ActiveTab = "chart";
            _ = InvokeAsync(StateHasChanged);
        }
        else if (evt is PhaseStartedEvent phaseStarted)
        {
            _currentPhaseIndex = phaseStarted.PhaseIndex;
            _currentPhaseName = phaseStarted.PhaseName;
        }
        else if (evt is AgentActivatedEvent activated2)
        {
            SetNodeStatus(activated2.Role.ToString(), "active", message);
            var activatedColor = GetAgentColor(activated2.Role.ToString());
            var taskDesc = activated2.TaskDescription;
            var roleName = activated2.Role.ToString();
            var phaseIdx = _currentPhaseIndex;
            _ = InvokeAsync(async () =>
            {
                if (_canvasChart is not null)
                {
                    await _canvasChart.ActivateNodeAsync(roleName, activatedColor, taskDesc);
                    await _canvasChart.DrawConnectionAsync("Orchestrator", roleName, activatedColor, true);
                    if (phaseIdx > 0)
                        await _canvasChart.AddNodePhaseAsync(roleName, phaseIdx);
                }
            });
        }
        else if (evt is AgentCompletedEvent completed2)
        {
            SetNodeStatus(completed2.Role.ToString(), "complete", message);
            var completedRole = completed2.Role.ToString();
            _ = InvokeAsync(async () =>
            {
                if (_canvasChart is not null)
                {
                    await _canvasChart.CompleteNodeAsync(completedRole);
                    await _canvasChart.DeactivateConnectionAsync("Orchestrator", completedRole);
                }
            });
        }
        else if (evt is OrchestrationCompletedEvent || evt is OrchestrationErrorEvent)
        {
            IsRunning = false;
            _ = InvokeAsync(async () =>
            {
                if (_canvasChart is not null)
                    await _canvasChart.DeactivateAllAsync();
            });
        }
        else if (evt is BuildValidationEvent buildEvt)
        {
            _buildSucceeded = buildEvt.Success;
            _lastBuildResult = buildEvt.Success
                ? "\u2705 Build validation passed."
                : $"\u274c Build validation failed:\n{buildEvt.Output}";
        }
        else if (evt is AgentCommunicationEvent comm)
        {
            SetNodeStatus(comm.FromAgent.ToString(), "active", $"Sending to {comm.ToAgent}");
            SetNodeStatus(comm.ToAgent.ToString(), "active", $"Receiving from {comm.FromAgent}");
            var commFromName = comm.FromAgent.ToString();
            var commToName = comm.ToAgent.ToString();
            var commColor = GetAgentColor(commToName);
            _ = InvokeAsync(async () =>
            {
                if (_canvasChart is not null)
                {
                    await _canvasChart.ActivateNodeAsync(commFromName, GetAgentColor(commFromName));
                    await _canvasChart.ActivateNodeAsync(commToName, commColor);
                    await _canvasChart.DrawConnectionAsync(commFromName, commToName, commColor, true);
                }
            });
        }
        else if (evt is AppLaunchedEvent)
        {
            IsAppRunning = true;
        }
        else if (evt is AppStoppedEvent)
        {
            IsAppRunning = false;
        }

        _ = InvokeAsync(StateHasChanged);
    }

    private void TrackAgentCall(OrchestrationEvent evt)
    {
        var now = DateTimeOffset.UtcNow;
        if (evt is AgentActivatedEvent active)
        {
            _callGraph.RecordCall(AgentRole.Orchestrator, active.Role, active.TaskDescription, now);
        }
        else if (evt is AgentCommunicationEvent comm)
        {
            _callGraph.RecordCall(comm.FromAgent, comm.ToAgent, comm.Summary, now);
        }
    }

    private void SetNodeStatus(string roleName, string status, string message)
    {
        var node = AgentNodes.FirstOrDefault(n => n.Name.Equals(roleName, StringComparison.OrdinalIgnoreCase));
        if (node == null)
        {
            if (AgentStyles.TryGetValue(roleName, out var style))
            {
                node = new AgentNodeState { Name = roleName, Color = style.Color, Icon = style.Icon };
            }
            else
            {
                node = new AgentNodeState { Name = roleName, Color = "#6c757d", Icon = "\U0001f916" };
            }
            AgentNodes.Add(node);
        }

        node.Status = status;
        node.Instruction = message.Length > 90 ? $"{message[..90]}..." : message;
    }

    private void ResetStatuses()
    {
        foreach (var node in AgentNodes)
        {
            node.Status = "idle";
            node.Instruction = "Idle";
        }
        AgentConnections.Clear();
    }

    // Resizable split pane
    private double LeftFlex { get; set; } = 1;
    private double RightFlex { get; set; } = 1;
    private bool _chatCollapsed;

    private void CollapseChat() => _chatCollapsed = true;
    private void ExpandChat() => _chatCollapsed = false;

    private void OnHandlePointerDown(PointerEventArgs e) { /* handled in JS */ }

    [JSInvokable]
    public void OnSplitResize(double leftPercent)
    {
        LeftFlex = leftPercent;
        RightFlex = 100 - leftPercent;
        InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var objRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("initSplitPane", objRef);
        }
    }

    private async Task<bool> GetAutoApproveSetting()
    {
        try
        {
            var setting = await JS.InvokeAsync<string?>("localStorage.getItem", "autoApprovePlans");
            return setting != "false"; // Default to true if not set
        }
        catch
        {
            return true; // Default to auto-approve
        }
    }
}
